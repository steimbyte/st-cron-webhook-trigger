{
  "name": "@cronboard/core",
  "version": "0.5.0",
  "description": "Cronboard backend: CLI, scheduler, HTTP server, JSON storage, actions",
  "private": true,
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "start": "tsx src/cli.ts",
    "start:detach": "tsx src/cli.ts start --detach",
    "stop": "tsx src/cli.ts stop",
    "status": "tsx src/cli.ts status",
    "logs": "tsx src/cli.ts logs",
    "ls": "tsx src/cli.ts ls",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "commander": "^12.1.0",
    "croner": "^8.1.2",
    "cronstrue": "^2.28.0",
    "fastify": "^5.9.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.1.0",
    "undici": "^6.18.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7"
  }
}
